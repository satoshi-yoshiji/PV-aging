set -euo pipefail
cd /humgen/diabetes2/users/satoshi/misc/02.aging

source /home/unix/yoshiji/anaconda3/etc/profile.d/conda.sh
conda activate ckd_analysis

echo "Host: $(hostname)"
echo "Started: $(date -Is)"

python run_section2_aging_prospective.py \
  --input /humgen/diabetes2/users/satoshi/misc/01.pv/curated_stats.tsv.gz \
  --outdir /humgen/diabetes2/users/satoshi/misc/02.aging/results \
  --seed 42

echo "Finished: $(date -Is)"
